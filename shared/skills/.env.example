# OverSteward Shared Skills — Environment Variables
#
# Copy this file to .env in any context that uses shared skills.
# Each context only needs the variables for skills it actually uses.
# This file is deployed alongside skills to ~/.claude/shared/skills/

# --- create-todoist-task ---
TODOIST_TOKEN=your_todoist_api_token
# Project IDs (get from Todoist Settings > Projects > click project > URL contains ID)
# TODOIST_PROJECT_INBOX=
# TODOIST_PROJECT_GOLDEN_HARVEST=
# TODOIST_PROJECT_GRANTS=
# TODOIST_PROJECT_REPORTING=
# TODOIST_PROJECT_MAJOR_GIFTS=
# TODOIST_PROJECT_AGENDAS=
# TODOIST_PROJECT_DIRECT_MAIL=
# TODOIST_PROJECT_DONOR_PERFECT=
# TODOIST_PROJECT_ONLINE_GIVING=
# TODOIST_PROJECT_HOME=
# TODOIST_PROJECT_MY_WORK=
# TODOIST_PROJECT_ALLELUIA=
# TODOIST_PROJECT_ROBOTICS=
